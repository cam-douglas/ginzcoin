# Copy to .env and fill values. Never commit .env.
# Quick start: cp .env.template .env

# Foundry / deploy script
FOUNDRY_PROFILE=default
PRIVATE_KEY=

# RPC (defaults in .env.template)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Verification — https://basescan.org/myapikey
ETHERSCAN_API_KEY=

# Addresses (fill after Safe creation / deploy)
DEPLOYER_EOA=
TEAM_SAFE_ADDRESS=
TREASURY_SAFE_ADDRESS=
COMMUNITY_WALLET_ADDRESS=
GINZ_TOKEN_ADDRESS=
TEAM_VESTING_ADDRESS=
UNISWAP_PAIR_ADDRESS=

# Frontend (apps/web — copy to apps/web/.env.local)
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_GINZ_ADDRESS=
NEXT_PUBLIC_WC_PROJECT_ID=
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
