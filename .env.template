# Copy to repo root as `.env` and fill the two required secrets.
# Never commit `.env`.

FOUNDRY_PROFILE=default

# REQUIRED for Phase 4A — deployer private key (0x-prefixed hex; script adds 0x if omitted)
PRIVATE_KEY=

# REQUIRED for verification — https://basescan.org/myapikey (works for Base Sepolia API)
ETHERSCAN_API_KEY=

# RPC (defaults work; override if you use Alchemy/Infura)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Testnet: leave unset — deploy script uses deployer as Team/Treasury/community placeholder
# Mainnet: set real Safe / wallet addresses before deploy
# TEAM_SAFE_ADDRESS=
# TREASURY_SAFE_ADDRESS=
# COMMUNITY_WALLET_ADDRESS=

# Filled automatically after deploy
# DEPLOYER_EOA=
# GINZ_TOKEN_ADDRESS=
# TEAM_VESTING_ADDRESS=

# Frontend local dev (optional — copy to apps/web/.env.local after Sepolia deploy)
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_GINZ_ADDRESS=
NEXT_PUBLIC_WC_PROJECT_ID=
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
